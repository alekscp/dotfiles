{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "input_submit": "<leader>return",
    "input_newline": "shift+return"
  },
  "provider": {
    "openai": {
      "models": {},
      "options": {
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}"
      }
    },
    "openrouter": {
      "models": {},
      "options": {
        "apiKey": "{env:OPENCODE_OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    },
    "deepseek": {
      "models": {},
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:OPENCODE_DEEPSEEK_API_KEY}"
      }
    }
  }
}
